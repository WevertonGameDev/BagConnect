#:import dp kivy.metrics.dp
#:import FitImage kivymd.uix.fitimage.FitImage

<Drawer>

    orientation: "vertical"

    md_bg_color: 1, 1, 1, 1

    size_hint: None, 1
    width: dp(280)

    padding: dp(18)
    spacing: dp(10)



    # CABEÇALHO
    MDBoxLayout:
        orientation: "vertical"

        adaptive_height: True

        spacing: dp(10)


        MDBoxLayout:
            adaptive_height: True

            Widget:

            MDIconButton:
                icon: "close"

                theme_text_color: "Custom"

                text_color: .90, .30, .30, 1

                on_release:
                    app.root.get_screen("home").fechar_menu()


        FitImage:
            source: root.foto

            size_hint: None, None

            size: dp(90), dp(90)

            radius: [45]

            pos_hint:
                {"center_x": .5}

        MDLabel:
            text: root.nome

            halign: "center"

            bold: True

            font_style: "H6"

            adaptive_height: True

        MDLabel:
            text: root.email

            halign: "center"

            adaptive_height: True

            theme_text_color: "Secondary"

    MDSeparator:



    # MENU (ROLÁVEL)
    ScrollView:
        do_scroll_x: False
        bar_width: dp(3)

        MDBoxLayout:
            orientation: "vertical"

            adaptive_height: True

            spacing: dp(4)


            MDCard:
                elevation: 0

                radius: [10]

                md_bg_color: .92, .96, 1, 1

                size_hint_y: None

                height: dp(48)

                OneLineIconListItem:
                    text: app.tr("menu_home")

                    divider: None

                    theme_text_color: "Custom"

                    text_color: .10, .35, .80, 1

                    IconLeftWidget:
                        icon: "home"

                        theme_text_color: "Custom"

                        text_color: .10, .35, .80, 1


            OneLineIconListItem:
                text: app.tr("menu_bagagens")

                IconLeftWidget:
                    icon: "bag-suitcase"

            OneLineIconListItem:
                text: app.tr("menu_suporte")

                IconLeftWidget:
                    icon: "headset"

            OneLineIconListItem:
                text: app.tr("menu_perfil")

                IconLeftWidget:
                    icon: "account"

    MDSeparator:



    # RODAPÉ
    MDBoxLayout:
        orientation: "vertical"

        adaptive_height: True

        OneLineIconListItem:
            text: app.tr("menu_configuracoes")

            IconLeftWidget:
                icon: "cog"

        OneLineIconListItem:
            text: app.tr("menu_sair")

            IconLeftWidget:
                icon: "logout"