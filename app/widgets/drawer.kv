#:import dp kivy.metrics.dp
#:import FitImage kivymd.uix.fitimage.FitImage

<Drawer>

    orientation: "vertical"

    md_bg_color: app.theme_cls.bg_normal

    size_hint: None, 1
    width: dp(280)

    padding: dp(18)
    spacing: dp(10)

    # Botão Fechar
    MDBoxLayout:
        adaptive_height: True

        Widget:

        MDIconButton:
            icon: "close"
            theme_text_color: "Custom"
            text_color: 0.90, 0.30, 0.30, 1
            on_release:
                app.root.get_screen("home").fechar_menu()

    # Avatar
    FitImage:
        source: root.foto

        size_hint: None, None
        size: dp(90), dp(90)

        radius: [45]

        pos_hint:
            {"center_x": .5}

    # Nome
    MDLabel:
        text: root.nome

        halign: "center"

        bold: True

        font_style: "H6"

        adaptive_height: True

    # Email
    MDLabel:
        text: root.email

        halign: "center"

        adaptive_height: True

        theme_text_color: "Secondary"

    Widget:
        size_hint_y: None
        height: dp(10)

    MDSeparator:

    # HOME
    MDCard:

        elevation: 0

        radius: [10]

        md_bg_color: 0.92, 0.96, 1, 1

        size_hint_y: None

        height: dp(48)

        OneLineIconListItem:

            text: app.tr("menu_home")

            divider: None

            theme_text_color: "Custom"

            text_color: 0.10, 0.35, 0.80, 1

            on_release:
                root.abrir_home()

            IconLeftWidget:

                icon: "home"

                theme_text_color: "Custom"

                text_color: 0.10, 0.35, 0.80, 1

    # BAGAGENS
    OneLineIconListItem:

        text: app.tr("menu_bagagens")

        IconLeftWidget:

            icon: "bag-suitcase"

    # SUPORTE
    OneLineIconListItem:

        text: app.tr("menu_suporte")

        IconLeftWidget:

            icon: "headset"

    # PERFIL
    OneLineIconListItem:

        text: app.tr("menu_perfil")

        on_release:
            root.abrir_perfil()

        IconLeftWidget:

            icon: "account"

    Widget:

    MDSeparator:

    # CONFIGURAÇÕES
    OneLineIconListItem:

        text: app.tr("menu_configuracoes")

        on_release:
            app.root.get_screen("home").fechar_menu()
            app.root.current = "settings"

        IconLeftWidget:

        IconLeftWidget:
            icon: "cog"

    OneLineIconListItem:

        text: app.tr("menu_sair")

        IconLeftWidget:

            icon: "logout"