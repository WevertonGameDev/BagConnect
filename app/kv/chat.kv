#:import dp kivy.metrics.dp

<ChatScreen>

    MDBoxLayout:
        orientation: "vertical"

        MDTopAppBar:
            title: root.titulo

            elevation: 0

            left_action_items:
                [["arrow-left", lambda x: root.voltar()]]

        ScrollView:

            MDBoxLayout:
                id: mensagens

                orientation: "vertical"
                adaptive_height: True

                padding: dp(16)
                spacing: dp(12)

                MDCard:
                    orientation: "vertical"
                    adaptive_height: True
                    padding: dp(12)
                    radius: [16]

                    MDLabel:
                        text: root.mensagem_auto

                        adaptive_height: True

        MDSeparator:

        MDBoxLayout:
            adaptive_height: True
            padding: dp(10)
            spacing: dp(10)

            MDTextField:
                id: mensagem

                hint_text: root.digite

                mode: "rectangle"

            MDRaisedButton:
                text: root.enviar

                on_release:
                    root.enviar_mensagem()