#:import dp kivy.metrics.dp

<NewTicketScreen>

    MDBoxLayout:
        orientation: "vertical"

        MDTopAppBar:

            title: root.titulo

            elevation: 0

            left_action_items:
                [["arrow-left", lambda x: root.voltar()]]

        ScrollView:

            MDBoxLayout:
                orientation: "vertical"
                adaptive_height: True

                padding: dp(20)
                spacing: dp(18)

                MDLabel:
                    text: root.descricao_ticket

                    adaptive_height: True
                    theme_text_color: "Secondary"

                MDTextField:
                    id: assunto

                    hint_text: root.assunto

                    helper_text: root.campo_obrigatorio

                    helper_text_mode: "on_error"

                    mode: "rectangle"

                MDTextField:
                    id: descricao

                    hint_text: root.descricao_label

                    helper_text: root.campo_obrigatorio

                    helper_text_mode: "on_error"

                    multiline: True

                    mode: "rectangle"

                    height: dp(120)

                MDTextField:
                    id: cpf

                    hint_text: root.cpf

                    helper_text: root.campo_obrigatorio

                    helper_text_mode: "on_error"

                    mode: "rectangle"

                MDTextField:
                    id: codigo

                    hint_text: root.codigo_bagagem

                    helper_text: root.campo_obrigatorio

                    helper_text_mode: "on_error"

                    mode: "rectangle"

                MDRaisedButton:
                    text: root.criar

                    pos_hint:
                        {"center_x": .5}

                    on_release:
                        root.criar_ticket()

                Widget:
                    size_hint_y: None
                    height: dp(20)