# app/kv/find_bags.kv

<FindBagsScreen>:
    MDBoxLayout:
        orientation: 'vertical'
        padding: dp(16)
        spacing: dp(12)

        # Botão Superior com a Setinha de Voltar
        MDBoxLayout:
            size_hint_y: None
            height: dp(48)

            MDIconButton:
                icon: "arrow-left"
                on_release: app.root.current = "home"

            Widget: # Espaçador para manter o botão alinhado à esquerda

        MDLabel:
            text: "Encontrar Bagagem"
            font_style: "H5"
            bold: True
            size_hint_y: None
            height: self.texture_size[1]

        # Campos de Busca
        MDTextField:
            id: cpf_input
            hint_text: "CPF (ex: 123.456.789-00)"
            icon_left: "card-account-details"
            size_hint_y: None
            height: dp(60)

        MDTextField:
            id: codigo_input
            hint_text: "Código da Bagagem (ex: BAG-2026-001)"
            icon_left: "barcode-scan"
            size_hint_y: None
            height: dp(60)

        MDRaisedButton:
            text: "Buscar"
            icon: "magnify"
            size_hint_x: 1
            on_release: root.buscar_bagagem()

        # Mensagem de Erro
        MDLabel:
            id: lbl_mensagem_erro
            text: ""
            theme_text_color: "Error"
            halign: "center"
            size_hint_y: None
            height: self.texture_size[1]

        # Card de Resultado (Inicia invisível/desativado)
        ScrollView:
            MDCard:
                id: card_resultado
                orientation: 'vertical'
                padding: dp(16)
                spacing: dp(8)
                radius: [12,]
                elevation: 2
                size_hint_y: None
                height: self.minimum_height
                opacity: 0
                disabled: True

                MDBoxLayout:
                    size_hint_y: None
                    height: dp(30)
                    spacing: dp(8)

                    MDIcon:
                        icon: "bag-suitcase"
                        theme_text_color: "Custom"
                        text_color: 0, 0.6, 0.2, 1

                    MDLabel:
                        text: "Bag encontrada"
                        font_style: "Subtitle1"
                        bold: True

                MDSeparator:

                # Badge de Status Em Destaque
                MDLabel:
                    id: lbl_status
                    text: "🟢 Status: Em transporte"
                    theme_text_color: "Custom"
                    text_color: 0.1, 0.7, 0.3, 1
                    bold: True
                    size_hint_y: None
                    height: dp(24)

                # Informações do Passageiro e Voo
                MDLabel:
                    id: lbl_codigo
                    text: ""
                    font_style: "Body2"
                    size_hint_y: None
                    height: dp(20)

                MDLabel:
                    id: lbl_passageiro
                    text: ""
                    font_style: "Body2"
                    size_hint_y: None
                    height: dp(20)

                MDLabel:
                    id: lbl_cpf
                    text: ""
                    font_style: "Body2"
                    size_hint_y: None
                    height: dp(20)

                MDLabel:
                    id: lbl_companhia
                    text: ""
                    font_style: "Body2"
                    size_hint_y: None
                    height: dp(20)

                MDLabel:
                    id: lbl_rota
                    text: ""
                    font_style: "Body2"
                    bold: True
                    size_hint_y: None
                    height: dp(20)

                MDLabel:
                    id: lbl_despacho
                    text: ""
                    font_style: "Caption"
                    theme_text_color: "Hint"
                    size_hint_y: None
                    height: dp(18)

                MDSeparator:

                # Rastreamento e Tempo
                MDBoxLayout:
                    size_hint_y: None
                    height: dp(24)
                    spacing: dp(6)

                    MDIcon:
                        icon: "map-marker"
                        size_hint_x: None
                        width: dp(20)

                    MDLabel:
                        id: lbl_localizacao
                        text: ""
                        font_style: "Caption"

                MDBoxLayout:
                    size_hint_y: None
                    height: dp(24)
                    spacing: dp(6)

                    MDIcon:
                        icon: "clock-outline"
                        size_hint_x: None
                        width: dp(20)

                    MDLabel:
                        id: lbl_atualizacao
                        text: ""
                        font_style: "Caption"

                MDBoxLayout:
                    size_hint_y: None
                    height: dp(24)
                    spacing: dp(6)

                    MDIcon:
                        icon: "run-fast"
                        size_hint_x: None
                        width: dp(20)

                    MDLabel:
                        id: lbl_previsao
                        text: ""
                        font_style: "Caption"
                        bold: True