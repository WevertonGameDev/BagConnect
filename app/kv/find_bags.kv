#:import dp kivy.metrics.dp

<FindBagsScreen>

    md_bg_color: app.theme_cls.bg_normal

    MDBoxLayout:
        orientation: "vertical"

        MDTopAppBar:
            title: root.titulo

            elevation: 0

            left_action_items:
                [["arrow-left", lambda x: root.voltar()]]

            right_action_items:
                [["history", lambda x: root.abrir_historico()]]

            md_bg_color: app.theme_cls.bg_normal

        ScrollView:

            AnchorLayout:
                anchor_x: "center"
                anchor_y: "top"

                size_hint_y: None
                height: content.height

                MDBoxLayout:
                    id: content

                    orientation: "vertical"

                    adaptive_height: True

                    size_hint_x: None
                    width: min(root.width - dp(40), dp(560))

                    padding: dp(20)

                    spacing: dp(18)

                    MDSeparator:

                    MDLabel:
                        text: root.cpf_titulo

                        bold: True
                        adaptive_height: True

                    MDTextField:
                        id: cpf

                        hint_text: root.cpf_hint

                        helper_text: root.cpf_helper

                        helper_text_mode: "on_focus"

                    MDLabel:

                        text: root.codigo_titulo

                        bold: True
                        adaptive_height: True

                    MDTextField:
                        id: codigo

                        hint_text: root.codigo_hint

                        helper_text: root.codigo_helper

                        helper_text_mode: "on_focus"

                    MDRaisedButton:
                        text: root.botao_consultar

                        size_hint_x: 1

                        on_release:
                            root.consultar_bagagem()

                    MDSeparator:

                    MDLabel:
                        text: root.resultado_titulo

                        font_style: "H6"

                        bold: True

                        adaptive_height: True

                    MDCard:
                        id: resultado_card

                        orientation: "vertical"

                        adaptive_height: True

                        size_hint_y: None

                        padding: dp(18)

                        spacing: dp(10)

                        radius: [18]

                        elevation: 4

                        opacity: 0

                        MDLabel:
                            id: bag_codigo

                            text: ""

                            bold: True

                            adaptive_height: True

                        MDSeparator:

                        MDLabel:
                            text: root.status_label

                            bold: True

                            adaptive_height: True

                        MDLabel:
                            id: bag_status

                            text: ""

                            adaptive_height: True

                            theme_text_color: "Secondary"

                        MDSeparator:

                        MDLabel:
                            id: bag_descricao

                            text: ""

                            adaptive_height: True

                            theme_text_color: "Secondary"

                    Widget:
                        size_hint_y: None
                        height: dp(20)