#:import dp kivy.metrics.dp
#:import FitImage kivymd.uix.fitimage.FitImage

<HomeScreen>

    md_bg_color: app.theme_cls.bg_normal

    FloatLayout:

        # CONTEÚDO PRINCIPAL
        MDBoxLayout:
            orientation: "vertical"
            size_hint: 1, 1

            MDTopAppBar:
                title: ""
                elevation: 0
                left_action_items: [["menu", lambda x: root.abrir_menu()]]
                md_bg_color: app.theme_cls.bg_normal

            ScrollView:

                AnchorLayout:
                    anchor_x: "center"
                    anchor_y: "top"
                    size_hint_y: None
                    height: content.height

                    MDBoxLayout:
                        id: content

                        orientation: "vertical"

                        adaptive_height: True

                        size_hint_x: None

                        width: min(root.width - dp(40), dp(560))

                        padding: dp(20)

                        spacing: dp(18)

                        MDLabel:
                            text: root.ola + ", " + root.nome_usuario + "!"
                            font_style: "H4"
                            bold: True
                            adaptive_height: True

                        MDSeparator:

                        MDCard:
                            size_hint_y: None
                            height: self.width / 2

                            radius: [18]

                            elevation: 5

                            FitImage:
                                source: "assets/images/banner_home.jpeg"
                                radius: [18]

                        MDSeparator:

                        # CARD BAGAGENS
                        MDCard:

                            size_hint_y: None
                            height: dp(150)

                            radius: [18]

                            elevation: 4

                            MDBoxLayout:

                                orientation: "vertical"

                                padding: dp(18)

                                spacing: dp(6)

                                MDLabel:
                                    text: root.home_bagagens_titulo
                                    font_style: "H6"
                                    bold: True
                                    adaptive_height: True

                                MDLabel:
                                    text: root.home_bagagens_texto
                                    adaptive_height: True
                                    theme_text_color: "Secondary"
                                    text_size: self.width, None

                                Widget:

                                MDRaisedButton:
                                    text: root.home_botao_bagagem

                                    size_hint: None, None

                                    size: dp(180), dp(38)

                                    on_release:
                                        root.abrir_bags()

                        # CARD SUPORTE
                        MDCard:

                            size_hint_y: None
                            height: dp(150)

                            radius: [18]

                            elevation: 4

                            MDBoxLayout:

                                orientation: "vertical"

                                padding: dp(18)

                                spacing: dp(6)

                                MDLabel:
                                    text: root.home_suporte_titulo
                                    font_style: "H6"
                                    bold: True
                                    adaptive_height: True

                                MDLabel:
                                    text: root.home_suporte_texto
                                    adaptive_height: True
                                    theme_text_color: "Secondary"
                                    text_size: self.width, None

                                Widget:

                                MDRaisedButton:
                                    text: root.home_botao_suporte

                                    size_hint: None, None

                                    size: dp(140), dp(38)

                                    on_release:
                                        root.abrir_chat()

                        Widget:
                            size_hint_y: None
                            height: dp(20)

        # OVERLAY ESCURO
        Button:
            id: overlay

            background_normal: ""
            background_down: ""

            background_color: 0, 0, 0, .35

            opacity: 0

            disabled: True

            size_hint: None, None
            size: 0, 0

            on_release:
                root.fechar_menu()

        # DRAWER
        Drawer:
            id: drawer

            x: -self.width

            y: 0

            size_hint: None, 1