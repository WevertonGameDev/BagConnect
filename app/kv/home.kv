#:kivy 2.0.0

<HomeScreen>:


    md_bg_color: 0.96, 0.97, 0.98, 1



    MDBoxLayout:

        orientation: "vertical"

        padding: dp(25)

        spacing: dp(20)



        MDLabel:

            text: app.tr("home_ola")

            font_style: "H4"

            bold: True

            size_hint_y: None

            height: dp(60)



        MDLabel:

            text: app.tr("home_bem_vindo")

            theme_text_color: "Secondary"

            size_hint_y: None

            height: dp(35)



        MDCard:


            orientation: "vertical"

            padding: dp(25)

            spacing: dp(10)

            size_hint_y: None

            height: dp(160)

            radius: [25]

            elevation: 8



            MDLabel:

                text: app.tr("home_suporte")

                font_style: "H5"

                bold: True



            MDLabel:

                text: app.tr("home_suporte_texto")

                theme_text_color: "Secondary"



            MDRaisedButton:

                text: app.tr("home_botao_chat")

                on_release:

                    root.abrir_chat()




        MDCard:


            orientation: "vertical"

            padding: dp(25)

            spacing: dp(10)

            size_hint_y: None

            height: dp(160)

            radius: [25]

            elevation: 8



            MDLabel:

                text: app.tr("home_bags")

                font_style: "H5"

                bold: True



            MDLabel:

                text: app.tr("home_bags_texto")

                theme_text_color: "Secondary"



            MDRaisedButton:

                text: app.tr("home_botao_bags")

                on_release:

                    root.abrir_bags()



        Widget:



        MDLabel:

            text: app.tr("app_nome")

            halign: "center"

            theme_text_color: "Secondary"