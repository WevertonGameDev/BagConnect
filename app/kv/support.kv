#:import dp kivy.metrics.dp

<SupportScreen>

    MDBoxLayout:
        orientation: "vertical"

        MDTopAppBar:
            title: app.tr("suporte_titulo", "Suporte Online")

            elevation: 0

            left_action_items:
                [["arrow-left",
                lambda x: root.voltar()]]

        MDBoxLayout:
            orientation: "vertical"

            padding: dp(20)

            spacing: dp(20)

            MDCard:
                radius: [18]

                elevation: 2

                adaptive_height: True

                padding: dp(20)

                orientation: "vertical"

                spacing: dp(12)

                MDLabel:
                    text: app.tr("suporte_sem_tickets", "Você ainda não possui tickets.")

                    halign: "center"

                    adaptive_height: True

            MDRaisedButton:
                text: app.tr("suporte_novo_ticket", "Novo Ticket")

                pos_hint:
                    {"center_x": .5}

                on_release:
                    root.novo_ticket()