#:kivy 2.0.0

<RegisterScreen>:


    MDBoxLayout:

        orientation: "vertical"

        padding: dp(40)

        spacing: dp(20)



        Widget



        MDLabel:

            text: app.tr("cadastro_titulo")

            halign: "center"

            font_style: "H3"



        MDLabel:

            text: app.tr("cadastro_subtitulo")

            halign: "center"

            theme_text_color: "Secondary"



        MDCard:


            orientation: "vertical"

            padding: dp(25)

            spacing: dp(15)

            size_hint_y: None

            height: dp(420)

            radius: [20]

            elevation: 8



            MDTextField:

                id: name

                hint_text: app.tr("campo_nome")

                icon_left: "account"



            MDTextField:

                id: email

                hint_text: app.tr("campo_email")

                icon_left: "email"



            MDTextField:

                id: password

                hint_text: app.tr("campo_senha")

                password: True

                icon_left: "lock"



            MDTextField:

                id: confirm_password

                hint_text: app.tr("campo_confirmar_senha")

                password: True

                icon_left: "lock-check"



            MDRaisedButton:

                text: app.tr("cadastro_botao")

                size_hint_x: 1


                on_release:

                    root.cadastrar()



        MDTextButton:


            text: app.tr("ja_tenho_conta")


            pos_hint:

                {
                "center_x": .5
                }


            on_release:

                root.voltar_login()



        Widget