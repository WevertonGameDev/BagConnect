#:kivy 2.0.0
#:import dp kivy.metrics.dp

<RegisterScreen>:

    MDBoxLayout:
        orientation: "vertical"

        padding: dp(40)

        spacing: dp(20)

        Widget:

        MDLabel:
            text: root.titulo

            halign: "center"

            font_style: "H3"

        MDLabel:

            text: root.subtitulo

            halign: "center"

            theme_text_color: "Secondary"

        MDCard:
            orientation: "vertical"

            padding: dp(25)

            spacing: dp(15)

            size_hint_y: None

            height: dp(450)

            radius: [20]

            elevation: 8

            MDTextField:
                id: name

                hint_text: root.campo_usuario

                icon_left: "account"

                on_text:
                    root.validar_campos()

            MDTextField:
                id: email

                hint_text: root.campo_email

                icon_left: "email"

                on_text:
                    root.validar_campos()

            MDBoxLayout:
                adaptive_height: True

                spacing: dp(5)

                MDTextField:
                    id: password

                    hint_text: root.campo_senha

                    password: True

                    icon_left: "lock"

                    on_text:
                        root.validar_campos()

                MDIconButton:
                    id: btn_password

                    icon: "eye-off"

                    pos_hint:
                        {"center_y": .5}

                    on_release:
                        root.mostrar_senha()
                        self.icon = "eye" if self.icon == "eye-off" else "eye-off"

            MDBoxLayout:
                adaptive_height: True

                spacing: dp(5)

                MDTextField:
                    id: confirm_password

                    hint_text: root.campo_confirmar_senha

                    password: True

                    icon_left: "lock-check"

                    on_text:
                        root.validar_campos()

                MDIconButton:
                    id: btn_confirm

                    icon: "eye-off"

                    pos_hint:
                        {"center_y": .5}

                    on_release:
                        root.mostrar_confirmar_senha()
                        self.icon = "eye" if self.icon == "eye-off" else "eye-off"

            MDRaisedButton:
                id: register_button

                text: root.botao_cadastrar

                size_hint_x: 1

                height: dp(46)

                disabled: True

                on_release:
                    root.cadastrar()

        MDTextButton:
            text: root.ja_tenho_conta

            pos_hint:
                {"center_x": .5}

            on_release:
                root.voltar_login()

        Widget: